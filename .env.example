# ═══════════════════════════════════════════════════════════════════════════════
# TecMan — Variables de Entorno (Ejemplo)
# ═══════════════════════════════════════════════════════════════════════════════
#
# Copia este archivo como .env y completa con tus valores reales:
#   cp .env.example .env
#
# Este archivo .env se lee desde:
#   - ecosystem.config.js (parsing manual para definir puertos en PM2)
#   - backend/src/app.module.ts (ConfigModule)
#   - frontend/next.config.mjs (lectura directa con fs)
# ═══════════════════════════════════════════════════════════════════════════════

# ── PUERTOS ──────────────────────────────────────────────────────────────────
PORT=3001                       # Backend NestJS (API, AdminJS, WebSocket)
FRONTEND_PORT=3000              # Frontend Next.js (puerto público)
API_PORT=3001                   # Backend (para el proxy del frontend)

# ── BASE DE DATOS ────────────────────────────────────────────────────────────
DATABASE_URL="mysql://root:password@127.0.0.1:3306/egan_tecman"

# ── AUTENTICACIÓN JWT ───────────────────────────────────────────────────────
JWT_SECRET=""
JWT_EXPIRES_IN="8h"
JWT_REFRESH_SECRET=""
JWT_REFRESH_EXPIRES_IN="7d"

# ── SERVIDOR ─────────────────────────────────────────────────────────────────
NODE_ENV="development"
FRONTEND_URL="http://localhost:3000"
PRODUCTION_URL=""                    # URL pública (ej: http://190.14.232.222:2024)

# ── DISCOVERY AGENT ─────────────────────────────────────────────────────────
DISCOVERY_API_KEY=""

# ── ALMACENAMIENTO ──────────────────────────────────────────────────────────
STORAGE_TYPE=local
STORAGE_PATH=./uploads

# ── S3/MinIO (opcional) ─────────────────────────────────────────────────────
# S3_ENDPOINT=http://localhost:9000
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin
# S3_BUCKET=tecman

# ── SMTP (opcional) ─────────────────────────────────────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=tu-correo@gmail.com
# SMTP_PASS=tu-contraseña-de-aplicacion
