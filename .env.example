# ═══════════════════════════════════════════════════════════════════════════════
# TecMan — Variables de Entorno (Ejemplo)
# ═══════════════════════════════════════════════════════════════════════════════
#
# Copia este archivo como .env y completa con tus valores reales:
#   cp .env.example .env
#
# Este archivo .env se lee desde:
#   - ecosystem.config.js (parsing manual para definir puertos en PM2)
#   - backend/.env       → via env_file en PM2 o dotenv
#   - frontend/next.config.mjs → lectura directa con fs
# ═══════════════════════════════════════════════════════════════════════════════

# ── PUERTOS ──────────────────────────────────────────────────────────────────
# DEFINIDOS ÚNICAMENTE AQUÍ. NO se hardcodean en ecosystem.config.js.

PORT=3001                       # Backend NestJS (API, AdminJS, WebSocket)
FRONTEND_PORT=3000              # Frontend Next.js (puerto público)
API_PORT=3001                   # Backend (para el proxy del frontend)

# ── BASE DE DATOS ────────────────────────────────────────────────────────────
# Cadena de conexión MySQL/MariaDB para Prisma ORM.
# Formato: mysql://USUARIO:CONTRASEÑA@HOST:PUERTO/BASE_DE_DATOS
DATABASE_URL="mysql://root:password@127.0.0.1:3306/egan_tecman"

# ── AUTENTICACIÓN JWT ───────────────────────────────────────────────────────
# ¡OBLIGATORIO! Secreto para firmar JWT.
# Genera uno fuerte con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=""

# Tiempo de expiración del access token (formato ms)
# Ejemplos: "15m", "30m", "1h", "8h"
JWT_EXPIRES_IN="8h"

# Tiempo de expiración del refresh token (en días 'd' u horas 'h')
# Se almacena en cookie httpOnly (NO va en localStorage)
# Ejemplos: "7d", "14d", "30d"
JWT_REFRESH_EXPIRES_IN="7d"

# ── SERVIDOR ─────────────────────────────────────────────────────────────────
# Modo de ejecución: "development" | "production" | "test"
NODE_ENV="production"

# URL completa del frontend (para CORS, WebSocket, notificaciones email)
FRONTEND_URL="http://localhost:3000"

# ── DISCOVERY AGENT ─────────────────────────────────────────────────────────
# API Key para autenticar agentes de descubrimiento (header X-API-Key).
# Si no se define, se usa una clave por defecto NO SEGURA.
# Genera una fuerte con:
#   node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
DISCOVERY_API_KEY=""

# ── SMTP ─────────────────────────────────────────────────────────────────────
# Configuración de servidor de correo para notificaciones.
# Descomenta y configura cuando tengas acceso SMTP.
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT=587
# SMTP_USER="tu-correo@gmail.com"
# SMTP_PASS="tu-contraseña-de-aplicacion"
