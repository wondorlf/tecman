# ── TecMan — Variables de Entorno (Ejemplo) ──────────────────────────────────
# Copie a .env y complete con sus valores reales
# cp .env.example .env

# ── PUERTOS ───────────────────────────────────────────────────────────────────
# DEFINIDOS AQUÍ ÚNICAMENTE. NO se hardcodean en ecosystem.config.js.
PORT=3001                       # Backend (API, AdminJS, WS)
FRONTEND_PORT=3000              # Frontend (Next.js)

# ── Base de datos ─────────────────────────────────────────────────────────────
# Formato: mysql://usuario:password@host:puerto/base_datos
DATABASE_URL="mysql://root:password@127.0.0.1:3306/egan_tecman"

# ── JWT ───────────────────────────────────────────────────────────────────────
# Genere un secreto fuerte con: openssl rand -hex 64
JWT_SECRET="cambiar-por-secreto-seguro-aqui"
JWT_EXPIRES_IN="8h"
JWT_REFRESH_EXPIRES_IN="7d"

# ── Servidor ──────────────────────────────────────────────────────────────────
NODE_ENV="production"
FRONTEND_URL=http://localhost:3000

# ── Discovery Agent ───────────────────────────────────────────────────────────
DISCOVERY_API_KEY=""
