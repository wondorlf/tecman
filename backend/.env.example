# ═══════════════════════════════════════════════════════════════════════════════
# TecMan Backend — Variables de Entorno (Ejemplo)
# ═══════════════════════════════════════════════════════════════════════════════
#
# Copia este archivo como .env y ajusta los valores para tu entorno:
#   cp .env.example .env
#
# NOTA: La mayoría de las variables se definen en el .env RAÍZ del proyecto.
# Este archivo existe como respaldo/documentación por si ejecutas el backend
# de forma independiente (sin PM2).
# ═══════════════════════════════════════════════════════════════════════════════

# ── BASE DE DATOS (Prisma / MySQL) ──────────────────────────────────────────
# Cadena de conexión a MySQL/MariaDB.
# Formato: mysql://USUARIO:CONTRASEÑA@HOST:PUERTO/BD
DATABASE_URL="mysql://root:password@127.0.0.1:3306/egan_tecman"

# ── AUTENTICACIÓN JWT ───────────────────────────────────────────────────────
# ¡OBLIGATORIO! Secreto para firmar los JWT.
# Genera uno fuerte con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=""

# Tiempo de expiración del access token
# Ejemplos: "15m", "30m", "1h", "8h"
JWT_EXPIRES_IN="8h"

# Tiempo de expiración del refresh token (cookie httpOnly)
# Ejemplos: "7d", "14d", "30d"
JWT_REFRESH_EXPIRES_IN="7d"

# ── SERVIDOR ─────────────────────────────────────────────────────────────────
PORT=3001                       # Puerto del backend
NODE_ENV="development"          # "development" | "production" | "test"
FRONTEND_URL="http://localhost:3000"  # URL del frontend (CORS, WS, emails)

# ── DISCOVERY AGENT ─────────────────────────────────────────────────────────
DISCOVERY_API_KEY=""            # API Key para agentes de discovery
