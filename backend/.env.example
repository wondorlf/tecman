# =============================================================================
# TecMan Backend — Variables de Entorno
# Copia este archivo como .env y ajusta los valores para tu entorno.
# =============================================================================

# ── Base de datos (Prisma / MySQL) ──────────────────────────────────────────
# Cadena de conexión a MySQL/MariaDB.
# Formato: mysql://USUARIO:CONTRASEÑA@HOST:PUERTO/BD
DATABASE_URL="mysql://root:password@127.0.0.1:3306/egan_tecman"

# ── Autenticación JWT ────────────────────────────────────────────────────────
# ¡OBLIGATORIO! Secreto para firmar los JWT. NO compartir.
# Si no se define, el backend lanza un error al arrancar en modo producción.
# Genera uno fuerte con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=""

# Tiempo de expiración del access token (JWT corta duración).
# Formato: formatos estándar de `ms` (https://github.com/vercel/ms)
# Ejemplos: "15m", "30m", "1h", "8h"
JWT_EXPIRES_IN="15m"

# Tiempo de expiración del refresh token (almacenado en cookie httpOnly).
# Formato: número seguido de "d" (días) o "h" (horas).
# Ejemplos: "7d", "14d", "30d"
JWT_REFRESH_EXPIRES_IN="7d"

# ── Servidor ──────────────────────────────────────────────────────────────────
# Puerto donde escucha el backend NestJS.
PORT=3001

# Modo de ejecución. Controla seguridad de cookies (secure flag), CORS, logs.
# Valores: "development" | "production" | "test"
NODE_ENV="development"

# URL del frontend. Usada para:
#   - CORS (permitir solicitudes desde el frontend)
#   - WebSocket CORS (tickets.gateway)
#   - Cookie httpOnly: sameSite strict no requiere, pero se usa para validación
FRONTEND_URL="http://localhost:3000"

# ── Discovery Agent ───────────────────────────────────────────────────────────
# API Key que deben enviar los agentes de descubrimiento (header X-API-Key).
# Si no se define, se usa una clave por defecto NO SEGURA.
# Cámbiala por una clave fuerte: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
DISCOVERY_API_KEY=""

# ── Seguridad (adicional) ────────────────────────────────────────────────────
# Helmet y Throttler se configuran directamente en app.module.ts y main.ts.
# No requieren variables de entorno adicionales.
