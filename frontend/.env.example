# =============================================================================
# TecMan Frontend — Variables de Entorno
# Copia este archivo como .env.local y ajusta los valores.
# =============================================================================

# URL base de la API del backend (solo si el frontend NO usa proxy).
# En desarrollo con Next.js (puerto 3000), el proxy rewrite en next.config.mjs
# maneja /api/* automáticamente → no necesitas definir esta variable.
# Solo cuando el frontend estático se sirve desde otro puerto/origen se usa.
# NEXT_PUBLIC_API_URL="http://localhost:3001"
