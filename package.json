{
  "name": "egan-tecman",
  "version": "2.0.0",
  "private": true,
  "description": "TecMan — Sistema de Gestión de Activos y Mantenimiento",
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "cd backend && npm run build",
    "build:frontend": "cd frontend && npm run build",
    "start": "npm run build && npm run pm2:start",
    "start:fast": "npm run pm2:start",
    "stop": "npm run pm2:stop",
    "restart": "npm run pm2:restart",
    "logs": "pm2 logs",
    "status": "pm2 status",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop ecosystem.config.js",
    "pm2:restart": "pm2 restart ecosystem.config.js",
    "pm2:logs": "pm2 logs",
    "pm2:status": "pm2 status",
    "build:agent": "cd agent && go build -o tecman-discovery.exe .",
    "build:agent:node": "cd agent/node-agent && npm run build",
    "agent": "cd agent/node-agent && npm start",
    "build:fixes": "cd agent/node-agent && npm run build:fix",
    "build:tools": "cd tools && npm run build",
    "tools": "cd tools && npm start",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,prisma}\"",
    "db:generate": "cd backend && npx prisma@5.22.0 generate",
    "db:push": "cd backend && npx prisma@5.22.0 db push",
    "db:migrate": "cd backend && npx prisma@5.22.0 migrate dev",
    "db:seed": "cd backend && npx prisma@5.22.0 db seed",
    "db:studio": "cd backend && npx prisma@5.22.0 studio"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "pm2": "^5.3.0",
    "prettier": "^3.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}